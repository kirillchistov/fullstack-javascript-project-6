extends ../layouts/application.pug

block content
  h1.mb-4= t('views.labels.edit.header')
  +formFor()(action=route('oneLabel', { id: label.id }) method='post')
    input(type="hidden" name="_method" value="patch")
    +input(label, 'name', t('views.labels.name'), errors)(type="text" autofocus)
    +submit(label)(value=t('views.labels.edit.submit'))
