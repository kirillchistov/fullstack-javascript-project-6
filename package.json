{
  "name": "@hexlet/code",
  "version": "0.1.0",
  "type": "module",
  "description": "Hexlet Task Manager — система управления задачами на Fastify",
  "main": "./server/plugin.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --runInBand",
    "build": "webpack",
    "start": "fastify start server/plugin.js -a 0.0.0.0 -p ${PORT:-5000} -l info -P -o"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/__tests__/helpers/"
    ],
    "setupFiles": [
      "dotenv/config"
    ]
  },
  "author": "Kirill Chistov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirillchistov/fullstack-javascript-project-6.git"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/passport": "^3.0.2",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^10.1.0",
    "@fastify/view": "^12.0.0",
    "@vscode/sqlite3": "^5.1.2",
    "bootstrap": "^5.3.8",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-cli": "^8.0.0",
    "fastify-error-page": "^4.0.0",
    "fastify-objectionjs": "^2.0.1",
    "fastify-plugin": "^6.0.0",
    "fastify-reverse-routes": "^3.0.0",
    "i18next": "^26.3.6",
    "jquery": "^4.0.0",
    "knex": "^3.3.0",
    "lodash": "^4.17.23",
    "mini-css-extract-plugin": "^2.10.2",
    "objection": "^3.1.5",
    "objection-unique": "^1.2.2",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.3",
    "pug": "^3.0.4",
    "qs": "^6.15.3",
    "sqlite3": "^6.0.1",
    "webpack": "^5.108.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.7.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
