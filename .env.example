# Пример локальных переменных окружения. Скопируйте в .env и подставьте свои значения.
# Секреты не коммитьте в репозиторий — см. https://12factor.net/ru/config

SESSION_KEY=4fe91796c30bd989d95b62dc46c7c3ba0b6aa2df2187400586a4121c54c53b85
PORT=5001
NODE_ENV=development

# Серверный токен Rollbar (scope: post_server_item) — для Node.js/Fastify.
# Клиентский VITE_* токен (post_client_item) для этого приложения не подходит.
# ROLLBAR_ACCESS_TOKEN=your_post_server_item_token

# Опционально: клиентский токен, если позже понадобится Rollbar в браузере.
# VITE_ROLLBAR_ACCESS_TOKEN=your_post_client_item_token

# Для production на Render DATABASE_URL задаётся автоматически при подключении PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
